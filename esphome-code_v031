# ======================================================
# SPI
# ======================================================
spi:
  id: ${display_qspi_id}
  type: quad
  clk_pin: ${display_clk_pin}
  data_pins:
    - ${display_qspi_d0}
    - ${display_qspi_d1}
    - ${display_qspi_d2}
    - ${display_qspi_d3}

# ======================================================
# TOUCHSCREEN - gestito da LVGL
# ======================================================
touchscreen:
  - platform: cst816
    id: ${touch_panel_id}
    display: ${display_id}
    i2c_id: ${i2c_bus_id}
    address: ${touch_address}

    interrupt_pin:
      number: ${touch_interrupt_pin}
      mode: INPUT_PULLUP

    reset_pin:
      pca9554: ${io_expander_id}
      number: ${touch_reset_expander_pin}

    skip_probe: true

    transform:
      mirror_x: false
      mirror_y: false

    on_touch:
      - lambda: |-
          id(${touch_x_id}) = touch.x;
          id(${touch_y_id}) = touch.y;
          id(${touch_counter_id})++;
          id(${display_awake_until_id}) = millis() + 300000UL;
          id(aura_last_activity_ms) = millis();
          if (id(control_page_active)) {
            id(control_page_until) = millis() +
              (id(radio_page_active) ? 30000UL : 15000UL);
          }
      - script.execute: aura_wake_up

# ======================================================

display:
  - platform: mipi_spi
    id: ${display_id}
    model: JC3636W518V2
    spi_id: ${display_qspi_id}
    bus_mode: quad

    cs_pin: ${display_cs_pin}

    reset_pin:
      pca9554: ${io_expander_id}
      number: ${display_reset_expander_pin}

    dimensions:
      width: 360
      height: 360
      offset_width: 0
      offset_height: 0

    color_order: rgb
    invert_colors: false
    data_rate: 80MHz
    buffer_size: 100%
    auto_clear_enabled: false
    update_interval: never
    color_depth: 16

