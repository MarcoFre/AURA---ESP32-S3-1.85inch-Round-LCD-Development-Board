  # ======================================================
  # AURA - TIMER, CONNESSIONI E CONTROLLI
  # ======================================================
  - id: aura_refresh_runtime_ui
    mode: restart
    then:
      - lvgl.label.update:
          id: aura_time_label
          text: !lambda |-
            auto now = id(${rtc_id}).now();
            if (!now.is_valid()) {
              return std::string("--:--");
            }
            char buf[8];
            snprintf(buf, sizeof(buf), "%02d:%02d", now.hour, now.minute);
            return std::string(buf);

      - if:
          condition:
            lambda: return id(aura_sleeping);
          then:
            - lvgl.widget.hide: aura_time_plate
            - lvgl.widget.hide: aura_time_label
            - lvgl.widget.hide: aura_timer_plate
            - lvgl.widget.hide: aura_timer_label
            - lvgl.widget.hide: aura_timer_bar
          else:
            - if:
                condition:
                  lambda: return id(aura_music_mode);
                then:
                  - lvgl.widget.hide: aura_time_plate
                  - lvgl.widget.hide: aura_time_label
                  - lvgl.widget.hide: aura_timer_plate
                  - lvgl.widget.hide: aura_timer_label
                  - lvgl.widget.hide: aura_timer_bar
                else:
                  - if:
                      condition:
                        lambda: return id(${va_timer_active_display_id}) || id(${timer_ringing_switch_id}).state;
                      then:
                        - lvgl.widget.hide: aura_time_plate
                        - lvgl.widget.hide: aura_time_label
                        - lvgl.widget.show: aura_timer_plate
                        - lvgl.widget.show: aura_timer_label
                        - lvgl.widget.show: aura_timer_bar
                        - lvgl.label.update:
                            id: aura_timer_label
                            text: !lambda |-
                              if (id(${timer_ringing_switch_id}).state) {
                                return std::string("TIMER!");
                              }
                              uint32_t s = id(${va_timer_seconds_left_id});
                              char buf[24];
                              if (s >= 3600UL) {
                                snprintf(buf, sizeof(buf), "%02lu:%02lu:%02lu",
                                         (unsigned long)(s / 3600UL),
                                         (unsigned long)((s % 3600UL) / 60UL),
                                         (unsigned long)(s % 60UL));
                              } else {
                                snprintf(buf, sizeof(buf), "%02lu:%02lu",
                                         (unsigned long)(s / 60UL),
                                         (unsigned long)(s % 60UL));
                              }
                              return std::string(buf);
                        - lvgl.bar.update:
                            id: aura_timer_bar
                            value: !lambda |-
                              uint32_t total = id(${va_timer_total_seconds_id});
                              uint32_t left = id(${va_timer_seconds_left_id});
                              if (id(${timer_ringing_switch_id}).state) return 100;
                              if (total == 0) return 0;
                              int pct = (int)((left * 100UL) / total);
                              if (pct < 0) pct = 0;
                              if (pct > 100) pct = 100;
                              return pct;
                      else:
                        - lvgl.widget.show: aura_time_plate
                        - lvgl.widget.show: aura_time_label
                        - lvgl.widget.hide: aura_timer_plate
                        - lvgl.widget.hide: aura_timer_label
                        - lvgl.widget.hide: aura_timer_bar

      - lvgl.widget.update:
          id: aura_wifi_dot
          bg_color: !lambda |-
            return id(${wifi_component_id}).is_connected()
              ? lv_color_hex(0x22C55E)
              : lv_color_hex(0xEF4444);

      - lvgl.widget.update:
          id: aura_api_dot
          bg_color: !lambda |-
            return id(${api_component_id}).is_connected()
              ? lv_color_hex(0x22C55E)
              : lv_color_hex(0xF59E0B);

  - id: aura_refresh_controls
    mode: restart
    then:
      - lvgl.slider.update:
          id: aura_volume_slider
          animated: false
          value: !lambda |-
            float v = id(${media_player_id}).volume;
            if (v < 0.0f) v = 0.0f;
            if (v > 1.0f) v = 1.0f;
            return (int)(v * 100.0f + 0.5f);

      - lvgl.label.update:
          id: aura_volume_value_label
          text: !lambda |-
            int pct = (int)(id(${media_player_id}).volume * 100.0f + 0.5f);
            if (pct < 0) pct = 0;
            if (pct > 100) pct = 100;
            char buf[12];
            snprintf(buf, sizeof(buf), "%d%%", pct);
            return std::string(buf);

      - lvgl.label.update:
          id: aura_mute_label
          text: !lambda |-
            return id(ui_media_muted)
              ? std::string("AUDIO OFF")
              : std::string("AUDIO ON");

      - lvgl.widget.update:
          id: aura_mute_button
          bg_color: !lambda |-
            return id(ui_media_muted)
              ? lv_color_hex(0x7F1D1D)
              : lv_color_hex(0x0F3A4A);

      - lvgl.label.update:
          id: aura_va_label
          text: !lambda |-
            return id(${voice_assistant_id}).is_running()
              ? std::string("STOP VA")
              : std::string("AVVIA VA");

      - lvgl.label.update:
          id: aura_alarm_label
          text: !lambda |-
            return id(${antifurto_switch_id}).state
              ? std::string("ALLARME ON")
              : std::string("ALLARME OFF");

      - lvgl.widget.update:
          id: aura_alarm_button
          bg_color: !lambda |-
            return id(${antifurto_switch_id}).state
              ? lv_color_hex(0x7F1D1D)
              : lv_color_hex(0x0F3A4A);

  - id: ${script_va_local_volume_up_id}
    mode: restart
    then:
      - media_player.volume_up: ${media_player_id}
      - script.execute: aura_refresh_controls

  - id: ${script_va_local_volume_down_id}
    mode: restart
    then:
      - media_player.volume_down: ${media_player_id}
      - script.execute: aura_refresh_controls

  - id: ${script_va_local_mute_on_id}
    mode: restart
    then:
      - media_player.mute: ${media_player_id}

  - id: ${script_va_local_mute_off_id}
    mode: restart
    then:
      - media_player.unmute: ${media_player_id}

  - id: ${script_va_local_silent_on_id}
    mode: restart
    then:
      - switch.turn_on: ${mic_mute_switch_id}

  - id: ${script_va_stop_id}
    mode: restart
    then:
      - voice_assistant.stop:
      - lambda: |-
          id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
      - script.execute: ${script_ensure_wake_word_running_id}

  - id: ${script_va_local_alarm_on_id}
    mode: restart
    then:
      - switch.turn_on: ${antifurto_switch_id}

  - id: ${script_va_local_alarm_off_id}
    mode: restart
    then:
      - switch.turn_off: ${antifurto_switch_id}  

  - id: ${script_start_va_from_wake_word_id}
    mode: restart
    parameters:
      detected_wake_word: std::string
    then:
      - lambda: |-
          id(${wake_word_flow_active_id}) = true;
          id(${display_awake_until_id}) = millis() + 300000UL;
          id(${voice_assistant_phase_global_id}) = ${voice_assist_waiting_for_command_phase_id};
          id(${va_ultimo_input_ms_id}) = millis();

      - if:
          condition:
            switch.is_on: ${wake_sound_switch_id}
          then:
            - script.execute:
                id: ${script_play_sound_id}
                priority: false
                sound_file: !lambda return id(${wake_word_triggered_sound_id});

            # Piccola attesa per lasciare partire e finire il ding.
            # Se il file è più lungo, aumenta a 500/600ms.
            - delay: 400ms

      - if:
          condition:
            lambda: return id(${va_modalita_continua_id});
          then:
            - voice_assistant.start_continuous:
          else:
            - voice_assistant.start:
                wake_word: !lambda return detected_wake_word;

      - delay: 200ms
      - lambda: |-
          id(${wake_word_flow_active_id}) = false;

  - id: ${script_ensure_wake_word_running_id}
    mode: restart
    then:
      - delay: 800ms

      - if:
          condition:
            and:
              - api.connected:
              - voice_assistant.connected:
              - switch.is_off: ${mic_mute_switch_id}
              - switch.is_off: ${timer_ringing_switch_id}
              - not:
                  voice_assistant.is_running:
              - lambda: |-
                  return !id(${wake_word_flow_active_id});
              - lambda: |-
                  const auto s = id(${media_player_id}).state;
                  return s != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                         s != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
          then:
            - if:
                condition:
                  micro_wake_word.is_running:
                then:
                  - logger.log:
                      level: INFO
                      format: "==== MWW: gia attivo"
                else:
                  - logger.log:
                      level: INFO
                      format: "==== MWW: START sicuro"
                  - micro_wake_word.start:
          else:
            - logger.log:
                level: INFO
                format: "==== MWW: start saltato, condizioni non pronte"

  - id: ${script_ring_timer_id}
    then:
      - script.execute: ${script_enable_repeat_one_id}
      - script.execute:
          id: ${script_play_sound_id}
          priority: true
          sound_file: !lambda return id(${timer_finished_sound_id});

  - id: ${script_enable_repeat_one_id}
    then:
      - lambda: |-
          id(${media_player_id})
            ->make_call()
            .set_command(media_player::MediaPlayerCommand::MEDIA_PLAYER_COMMAND_REPEAT_ONE)
            .set_announcement(true)
            .perform();
          id(${media_player_id})->set_playlist_delay_ms(speaker::AudioPipelineType::ANNOUNCEMENT, 500);

  - id: ${script_disable_repeat_id}
    then:
      - lambda: |-
          id(${media_player_id})
            ->make_call()
            .set_command(media_player::MediaPlayerCommand::MEDIA_PLAYER_COMMAND_REPEAT_OFF)
            .set_announcement(true)
            .perform();
          id(${media_player_id})->set_playlist_delay_ms(speaker::AudioPipelineType::ANNOUNCEMENT, 0);

  - id: ${script_play_sound_id}
    parameters:
      priority: bool
      sound_file: "audio::AudioFile*"
    then:
      - lambda: |-
          if (priority) {
            id(${media_player_id})
              ->make_call()
              .set_command(media_player::MediaPlayerCommand::MEDIA_PLAYER_COMMAND_STOP)
              .set_announcement(true)
              .perform();
          }
          if ((id(${media_player_id}).state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING) || priority) {
            id(${media_player_id})->play_file(sound_file, true, false);
          }

  - id: ${script_fetch_first_active_timer_id}
    mode: single
    then:
      - lambda: |-
          static uint32_t last_fetch_time = 0;
          uint32_t now = millis();
          if (now - last_fetch_time < 500) return;
          last_fetch_time = now;

          const auto &timers = id(${voice_assistant_id}).get_timers();
          if (timers.empty()) return;

          auto output_timer = *timers.begin();
          for (const auto &timer : timers) {
            if (timer.is_active && timer.seconds_left <= output_timer.seconds_left) {
              output_timer = timer;
            }
          }
          id(${first_active_timer_id}) = output_timer;

  - id: ${script_check_if_timers_active_id}
    then:
      - lambda: |-
          const auto &timers = id(${voice_assistant_id}).get_timers();
          bool output = false;
          if (!timers.empty()) {
            for (const auto &timer : timers) {
              if (timer.is_active) {
                output = true;
                break;
              }
            }
          }
          id(${is_timer_active_id}) = output;

  - id: ${script_activate_stop_word_once_id}
    then:
      - delay: 1s
      - if:
          condition:
            switch.is_off: ${timer_ringing_switch_id}
          then:
            - micro_wake_word.enable_model: ${wake_word_stop_model_id}
            - wait_until:
                not:
                  media_player.is_announcing:
            - if:
                condition:
                  switch.is_off: ${timer_ringing_switch_id}
                then:
                  - micro_wake_word.disable_model: ${wake_word_stop_model_id}

  - id: ${script_check_alarm_id}
    then:
      - lambda: |-
          id(${script_publish_current_time_id}).execute();
          if (id(${alarm_on_switch_id}).state && id(${alarm_time_text_id}).has_state()) {
            auto set_alarm_time = id(${alarm_time_text_id}).state;
            if (set_alarm_time.length() == 5 &&
                isdigit(set_alarm_time[0]) && isdigit(set_alarm_time[1]) &&
                isdigit(set_alarm_time[3]) && isdigit(set_alarm_time[4])) {
              auto alarm_hour = std::stoi(set_alarm_time.substr(0, 2));
              auto alarm_minute = std::stoi(set_alarm_time.substr(3, 2));

              auto time_now = id(${rtc_id}).now();
              if (time_now.hour == alarm_hour && time_now.minute == alarm_minute) {
                auto action = id(${alarm_action_select_id}).state;
                if (action == "Riproduci suono") {
                  id(${timer_ringing_switch_id}).turn_on();
                } else if (action == "Invia evento") {
                  id(${script_send_alarm_event_id}).execute();
                } else if (action == "Suono ed evento") {
                  id(${timer_ringing_switch_id}).turn_on();
                  id(${script_send_alarm_event_id}).execute();
                }
              }
            } else {
              ESP_LOGW("alarm", "Incorrect alarm time setting");
            }
          }

  - id: ${script_send_alarm_event_id}
    then:
      - homeassistant.event:
          event: esphome.alarm_ringing

  - id: ${script_send_tts_uri_event_id}
    parameters:
      tts_uri: string
    then:
      - homeassistant.event:
          event: esphome.tts_uri
          data:
            uri: !lambda return tts_uri;

  - id: ${script_send_stt_text_event_id}
    parameters:
      stt_text: string
    then:
      - homeassistant.event:
          event: esphome.stt_text
          data:
            text: !lambda return stt_text;

  - id: ${script_publish_current_time_id}
    mode: single
    then:
      - lambda: |-
          static std::string last_time_string = "";
          auto time_now = id(${rtc_id}).now();
          std::string current_time_string = time_now.strftime("%H:%M");
          if (current_time_string != last_time_string) {
            id(${current_time_text_id}).publish_state(current_time_string);
            last_time_string = current_time_string;
          }

  - id: ${script_check_firmware_version_id}
    mode: restart
    then:
      - if:
          condition:
            lambda: return id(${fw_update_check_enabled_id});
          then:
            - logger.log:
                level: INFO
                format: "==== Firmware check: start"
            - http_request.get:
                url: "https://raw.githubusercontent.com/MarcoFre/ESP32-S3-AI-Smart-Speaker/main/OTA/version.yaml"
                capture_response: true
                max_response_buffer_size: 512
                on_response:
                  then:
                    - lambda: |-
                        if (response->status_code != 200) {
                          ESP_LOGW("fw_check", "HTTP status invalid: %d", response->status_code);
                          return;
                        }

                        std::string s = body;

                        while (!s.empty() && (s.back() == '\n' || s.back() == '\r' || s.back() == ' ' || s.back() == '\t')) s.pop_back();
                        while (!s.empty() && (s.front() == '\n' || s.front() == '\r' || s.front() == ' ' || s.front() == '\t')) s.erase(0, 1);

                        std::string latest = "";
                        const std::string key = "version:";
                        auto pos = s.find(key);
                        if (pos != std::string::npos) {
                          latest = s.substr(pos + key.length());
                          while (!latest.empty() && (latest.front() == ' ' || latest.front() == '\t')) latest.erase(0, 1);
                          while (!latest.empty() && (latest.back() == '\n' || latest.back() == '\r' || latest.back() == ' ' || latest.back() == '\t')) latest.pop_back();
                        }

                        if (latest.empty()) {
                          ESP_LOGW("fw_check", "Remote version not found");
                          return;
                        }

                        id(${fw_latest_version_id}) = latest;
                        id(${fw_update_available_id}) = (latest != std::string("${fw_version}"));

                        ESP_LOGI("fw_check",
                                 "Local=%s Remote=%s Update=%d",
                                 "${fw_version}",
                                 id(${fw_latest_version_id}).c_str(),
                                 (int) id(${fw_update_available_id}));

                        if (id(${fw_update_available_id})) {
                          id(${display_awake_until_id}) = millis() + 300000UL;
                        }
                on_error:
                  then:
                    - logger.log:
                        level: WARN
                        format: "==== Firmware check: HTTP error"

  - id: ${script_flash_ring_id}
    mode: restart
    then:
      - light.turn_on:
          id: ${display_backlight_id}
          brightness: 100%
      - delay: 120ms
      - light.turn_on:
          id: ${display_backlight_id}
          brightness: 80%

  - id: ${script_antifurto_trigger_id}
    mode: restart
    then:
      - lambda: |-
          id(${antifurto_alarm_in_corso_id}) = true;
          id(${display_awake_until_id}) = millis() + 300000UL;
          id(${display_startled_until_id}) = millis() + 2200UL;
      - logger.log:
          level: WARN
          format: "==== ANTIFURTO: rumore rilevato"

psram:
  mode: octal
  speed: 80MHz

time:
  - platform: homeassistant
    id: ${rtc_id}
    on_time:
      - seconds: 0
        minutes: /1
        then:
          - script.execute: ${script_check_alarm_id}
    on_time_sync:
      - script.execute: ${script_publish_current_time_id}

interval:

  # ----------------------------------------------------
  # BOOT ANIMATION LVGL - schema identico alla fonte
  # Tre oggetti aggiornati tramite global e widget.refresh.
  # ----------------------------------------------------
  - interval: 80ms
    then:
      - if:
          condition:
            and:
              - lambda: return !id(aura_boot_finished);
              - lvgl.page.is_showing: aura_boot_page
          then:
            - lambda: |-
                const uint32_t now = millis();
                const int cx = 180;
                const int cy = 180;
                const float PI2 = 6.2831853f;

                const float a_outer =
                  ((now % 4200UL) / 4200.0f) * PI2 - 1.5707963f;

                const float a_mid =
                  ((now % 2800UL) / 2800.0f) * PI2 + 0.45f;

                const float a_inner =
                  ((now % 1800UL) / 1800.0f) * PI2 + 2.10f;

                id(aura_boot_dot_outer_x) = cx + (int)(cosf(a_outer) * 150.0f);
                id(aura_boot_dot_outer_y) = cy + (int)(sinf(a_outer) * 150.0f);

                id(aura_boot_dot_mid_x) = cx + (int)(cosf(a_mid) * 116.0f);
                id(aura_boot_dot_mid_y) = cy + (int)(sinf(a_mid) * 116.0f);

                id(aura_boot_dot_inner_x) = cx + (int)(cosf(a_inner) * 81.0f);
                id(aura_boot_dot_inner_y) = cy + (int)(sinf(a_inner) * 81.0f);

            - lvgl.widget.refresh: aura_boot_dot_outer
            - lvgl.widget.refresh: aura_boot_dot_mid
            - lvgl.widget.refresh: aura_boot_dot_inner

  # ----------------------------------------------------
  # BOOT MANAGER - aggiorna stato e apre Aura quando pronta
  # ----------------------------------------------------
  - interval: 1s
    then:
      - if:
          condition:
            lambda: return !id(aura_boot_finished);
          then:
            - script.execute: aura_try_finish_boot

  # ----------------------------------------------------
  # AURA - MOTORE MUSICA / NOTE / VU METER
  # Il livello reale arriva da playback_peak. Se il valore
  # e assente o quasi fermo viene mantenuto un lieve ritmo
  # sintetico per non congelare l'animazione.
  # ----------------------------------------------------
  - interval: 80ms
    then:
      - if:
          condition:
            lambda: |-
              const auto state = id(${media_player_id}).state;
              const int phase = id(${voice_assistant_phase_global_id});

              const bool should_music =
                id(aura_assets_ready) &&
                state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                !id(${timer_ringing_switch_id}).state &&
                !id(${va_timer_active_display_id}) &&
                !id(aura_speaking) &&
                phase != ${voice_assist_waiting_for_command_phase_id} &&
                phase != ${voice_assist_listening_for_command_phase_id} &&
                phase != ${voice_assist_thinking_phase_id} &&
                phase != ${voice_assist_replying_phase_id};

              return should_music && !id(aura_music_mode);
          then:
            - script.execute: aura_start_music

      - if:
          condition:
            lambda: |-
              if (!id(aura_music_mode)) return false;

              const auto state = id(${media_player_id}).state;
              const int phase = id(${voice_assistant_phase_global_id});

              return state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING ||
                     id(${timer_ringing_switch_id}).state ||
                     id(${va_timer_active_display_id}) ||
                     id(aura_speaking) ||
                     phase == ${voice_assist_waiting_for_command_phase_id} ||
                     phase == ${voice_assist_listening_for_command_phase_id} ||
                     phase == ${voice_assist_thinking_phase_id} ||
                     phase == ${voice_assist_replying_phase_id};
          then:
            - script.execute: aura_stop_music

      - if:
          condition:
            lambda: return id(aura_music_mode) && id(aura_assets_ready);
          then:
            - lambda: |-
                const uint32_t now = millis();

                // VU musicale basato sul livello medio RMS, non sul picco.
                // Scala utile: -58 dB RMS = 0%, -1 dB RMS = 100%.
                // La curva 1.55 amplia la zona bassa e impedisce che il VU
                // resti costantemente a fondo scala con la musica normale.
                float real_level = 0.0f;
                const float rms_db = id(${playback_rms_sensor_id}).state;
                if (!std::isnan(rms_db) && !std::isinf(rms_db)) {
                  float normalized = (rms_db + 58.0f) / 57.0f;
                  if (normalized < 0.0f) normalized = 0.0f;
                  if (normalized > 1.0f) normalized = 1.0f;

                  real_level = powf(normalized, 1.55f);

                  if (rms_db <= -58.0f) {
                    real_level = 0.0f;
                  }
                }

                const float slow = (sinf(now / 310.0f) + 1.0f) * 0.5f;
                const float fast = (sinf(now / 105.0f) + 1.0f) * 0.5f;
                float pulse = sinf(now / 72.0f);
                if (pulse < 0.0f) pulse = 0.0f;
                pulse = pulse * pulse * pulse * pulse;

                const float synthetic =
                  0.10f + slow * 0.16f + fast * 0.18f + pulse * 0.38f;

                float target = real_level;
                if (target < 0.04f) {
                  target = synthetic * 0.72f;
                } else {
                  const float floor = synthetic * 0.20f;
                  if (target < floor) target = floor;
                }

                if (target > 1.0f) target = 1.0f;

                const float alpha =
                  target > id(aura_music_level) ? 0.58f : 0.14f;

                id(aura_music_level) +=
                  (target - id(aura_music_level)) * alpha;

                if (id(aura_music_level) < 0.0f) id(aura_music_level) = 0.0f;
                if (id(aura_music_level) > 1.0f) id(aura_music_level) = 1.0f;

            - lvgl.arc.update:
                id: aura_music_vu_arc
                value: !lambda |-
                  return (int)(id(aura_music_level) * 100.0f + 0.5f);
                indicator:
                  arc_color: !lambda |-
                    const float level = id(aura_music_level);
                    if (level >= 0.90f) return lv_color_hex(0xFF4614);
                    if (level >= 0.70f) return lv_color_hex(0xFFB900);
                    return lv_color_hex(0x00DC78);

            - lvgl.widget.refresh: aura_music_note_1
            - lvgl.widget.refresh: aura_music_note_2
            - lvgl.widget.refresh: aura_music_note_3
            - lvgl.widget.refresh: aura_music_note_4
            - lvgl.widget.refresh: aura_music_note_5
            - lvgl.widget.refresh: aura_music_note_6

            # Piccolo movimento continuo dell'intera immagine:
            # destra/sinistra e alto/basso, più evidente sui picchi.
            - lvgl.widget.update:
                id: aura_main_image
                x: !lambda |-
                  const float amp = 2.0f + id(aura_music_level) * 5.0f;
                  return (int)(sinf(millis() / 360.0f) * amp);
                y: !lambda |-
                  const float amp = 1.5f + id(aura_music_level) * 3.5f;
                  return -1 + (int)(sinf(millis() / 245.0f + 1.1f) * amp);

            - if:
                condition:
                  lambda: |-
                    return !id(aura_music_blinking) &&
                           millis() >= id(aura_music_next_pose_ms);
                then:
                  - script.execute: aura_music_next_pose

  # ----------------------------------------------------
  # AURA - SONNO / RISVEGLIO DOPO QUIETE
  # Rumore, touch, media, timer e VA mantengono Aura sveglia.
  # ----------------------------------------------------
  - interval: 250ms
    then:
      - lambda: |-
          const uint32_t now = millis();
          const auto state = id(${media_player_id}).state;
          const int phase = id(${voice_assistant_phase_global_id});

          if (id(aura_last_activity_ms) == 0) {
            id(aura_last_activity_ms) = now;
          }

          const bool active =
            !id(aura_boot_finished) ||
            id(control_page_active) ||
            id(aura_music_mode) ||
            id(aura_speaking) ||
            id(${noise_detected_binary_sensor_id}).state ||
            id(${timer_ringing_switch_id}).state ||
            id(${va_timer_active_display_id}) ||
            id(${display_emotion_mode_id}) != 0 ||
            phase != ${voice_assist_idle_phase_id} ||
            state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING ||
            state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;

          if (active) {
            id(aura_last_activity_ms) = now;
          }

      - if:
          condition:
            lambda: |-
              const auto state = id(${media_player_id}).state;
              const int phase = id(${voice_assistant_phase_global_id});
              const bool active =
                id(control_page_active) ||
                id(aura_music_mode) ||
                id(aura_speaking) ||
                id(${noise_detected_binary_sensor_id}).state ||
                id(${timer_ringing_switch_id}).state ||
                id(${va_timer_active_display_id}) ||
                id(${display_emotion_mode_id}) != 0 ||
                phase != ${voice_assist_idle_phase_id} ||
                state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING ||
                state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
              return id(aura_sleeping) && active;
          then:
            - script.execute: aura_wake_up

      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready) || !id(aura_boot_finished)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_last_activity_ms) == 0) return false;
              if ((uint32_t)(millis() - id(aura_last_activity_ms)) < id(aura_sleep_timeout_ms)) return false;

              const auto state = id(${media_player_id}).state;
              return !id(control_page_active) &&
                     !id(aura_music_mode) &&
                     !id(aura_speaking) &&
                     !id(${noise_detected_binary_sensor_id}).state &&
                     !id(${timer_ringing_switch_id}).state &&
                     !id(${va_timer_active_display_id}) &&
                     id(${display_emotion_mode_id}) == 0 &&
                     id(${voice_assistant_phase_global_id}) == ${voice_assist_idle_phase_id} &&
                     state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING &&
                     state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
          then:
            - script.execute: aura_go_to_sleep

      - if:
          condition:
            lambda: return id(aura_sleeping);
          then:
            - lvgl.widget.refresh: aura_sleep_z_1
            - lvgl.widget.refresh: aura_sleep_z_2
            - lvgl.widget.refresh: aura_sleep_z_3
            - lvgl.widget.refresh: aura_sleep_z_4

  # ----------------------------------------------------
  # AURA - CAMBIO FASE / STATO TIMER
  # ----------------------------------------------------
  - interval: 100ms
    then:
      - if:
          condition:
            lambda: |-
              // Durante il boot il testo e la pagina sono gestiti dal boot manager.
              if (!id(aura_assets_ready)) return false;

              bool timer_now = id(${timer_ringing_switch_id}).state;
              bool changed =
                id(aura_last_phase) != id(${voice_assistant_phase_global_id}) ||
                id(aura_last_timer_ringing) != timer_now;
              if (changed) {
                id(aura_last_timer_ringing) = timer_now;
              }
              return changed;
          then:
            - script.execute: aura_apply_phase

  # ----------------------------------------------------
  # AURA - ROTAZIONE ANELLO ESTERNO
  # ----------------------------------------------------
  - interval: 250ms
    then:
      - if:
          condition:
            and:
              - lambda: return id(aura_assets_ready) && !id(control_page_active) && !id(aura_sleeping);
              - lvgl.page.is_showing: aura_page
          then:
            - lambda: |-
                id(aura_outer_ring_rotation) += 2;
                if (id(aura_outer_ring_rotation) >= 360) {
                  id(aura_outer_ring_rotation) -= 360;
                }
            - lvgl.arc.update:
                id: aura_outer_arc_1
                rotation: !lambda return id(aura_outer_ring_rotation);
            - lvgl.arc.update:
                id: aura_outer_arc_2
                rotation: !lambda return id(aura_outer_ring_rotation);
            - lvgl.arc.update:
                id: aura_outer_arc_3
                rotation: !lambda return id(aura_outer_ring_rotation);
            - lvgl.arc.update:
                id: aura_outer_arc_4
                rotation: !lambda return id(aura_outer_ring_rotation);

  # ----------------------------------------------------
  # AURA - CONTROLLO BLINK
  # ----------------------------------------------------
  - interval: 500ms
    then:
      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (id(control_page_active)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_speaking)) return false;
              if (id(aura_animation_running)) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_idle_phase_id}) return false;
              if (id(${display_emotion_mode_id}) != 0) return false;
              if (id(aura_next_blink_ms) == 0) {
                id(aura_next_blink_ms) = millis() + 6000UL + (esp_random() % 14001UL);
                return false;
              }
              return (int32_t)(millis() - id(aura_next_blink_ms)) >= 0;
          then:
            - script.execute: aura_blink

  # ----------------------------------------------------
  # AURA - ESPRESSIONI CASUALI / UI RUNTIME / TIMEOUT
  # ----------------------------------------------------
  - interval: 1s
    then:
      - script.execute: aura_refresh_runtime_ui

      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (id(control_page_active)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(aura_speaking)) return false;
              if (id(aura_animation_running)) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_idle_phase_id}) return false;
              if (id(${display_emotion_mode_id}) != 0) return false;
              if (id(aura_next_expression_ms) == 0) {
                id(aura_next_expression_ms) = millis() + 15000UL + (esp_random() % 15001UL);
                return false;
              }
              return (int32_t)(millis() - id(aura_next_expression_ms)) >= 0;
          then:
            - script.execute: aura_random_idle_animation

      - if:
          condition:
            lambda: |-
              return id(control_page_active) &&
                     id(control_page_until) > 0 &&
                     (int32_t)(millis() - id(control_page_until)) >= 0;
          then:
            - script.execute: aura_show_main_page

  # ----------------------------------------------------
  # AURA - BOCCA AUDIO-REATTIVA DURANTE IL PARLATO
  # Riproduce la logica della lambda originale:
  # playback_peak -> smoothing -> sillaba/frase/chiusure -> frame LVGL.
  # ----------------------------------------------------
  - interval: 70ms
    then:
      - if:
          condition:
            lambda: |-
              if (!id(aura_assets_ready)) return false;
              if (!id(aura_speaking)) return false;
              if (id(control_page_active)) return false;
              if (id(aura_music_mode)) return false;
              if (id(aura_sleeping)) return false;
              if (id(${timer_ringing_switch_id}).state) return false;
              if (id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id}) return false;

              const auto mp_state = id(${media_player_id}).state;
              return mp_state == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING;
          then:
            - lambda: |-
                const uint32_t now = millis();

                auto clampf = [](float v, float lo, float hi) -> float {
                  if (v < lo) return lo;
                  if (v > hi) return hi;
                  return v;
                };

                // 1) Livello reale dell'audio, stessa conversione della lambda originale.
                float mouth_level = 0.0f;
                const float db = id(${playback_peak_sensor_id}).state;

                if (!std::isnan(db)) {
                  mouth_level = clampf((db + 68.0f) / 45.0f, 0.0f, 1.0f);
                  if (db < -62.0f) {
                    mouth_level = 0.0f;
                  }
                }

                // 2) Attacco rapido, rilascio più morbido.
                id(aura_mouth_smooth) +=
                  (mouth_level > id(aura_mouth_smooth) ? 0.55f : 0.18f) *
                  (mouth_level - id(aura_mouth_smooth));

                float mouth_anim = id(aura_mouth_smooth);

                // 3) Modulazione sillabica, andamento frase e micro-chiusure labiali.
                if (mouth_anim > 0.05f) {
                  const float syllable =
                    0.50f + 0.50f * ((sinf(now / 72.0f) + 1.0f) * 0.5f);

                  const float phrase =
                    0.72f + 0.28f * ((sinf(now / 210.0f + 1.4f) + 1.0f) * 0.5f);

                  const uint32_t cc = now % 640UL;

                  float closure =
                    (cc < 70UL)  ? 0.10f :
                    (cc < 115UL) ? 0.35f :
                                   1.00f;

                  if ((now % 2300UL) > 2100UL) {
                    closure *= 0.25f;
                  }

                  mouth_anim = clampf(
                    mouth_anim * syllable * phrase * closure,
                    0.0f,
                    1.0f
                  );
                }

                // 4) Conversione del livello continuo nei cinque frame disponibili.
                int next_frame = 0;

                if (id(aura_mouth_smooth) > 0.05f) {
                  if (mouth_anim < 0.25) {
                    next_frame = 0;
                  } else if (mouth_anim < 0.50f) {
                    next_frame = 1;
                  } else if (mouth_anim < 0.75) {
                    next_frame = 2;
                  } else {
                    next_frame = 3;
                  }
                }

                id(aura_speaking_frame) = next_frame;

            # Aggiorna l'immagine soltanto quando cambia il frame.
            - if:
                condition:
                  lambda: return id(aura_speaking_frame) != id(aura_last_speaking_frame);
                then:
                  - lambda: |-
                      id(aura_last_speaking_frame) = id(aura_speaking_frame);

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 0;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_idle_standby_img

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 1;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_small_open_mouth_img

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 2;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_open_mouth_img

                  - if:
                      condition:
                        lambda: return id(aura_speaking_frame) == 3;
                      then:
                        - lvgl.image.update:
                            id: aura_main_image
                            src: aura_more_open_mouth_img

      # Se il parlato è terminato o l'annuncio non è più attivo,
      # scarica rapidamente il livello residuo e richiude la bocca.
      - if:
          condition:
            lambda: |-
              if (!id(aura_speaking)) return false;
              const auto mp_state = id(${media_player_id}).state;
              return mp_state != media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING ||
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id} ||
                     id(${timer_ringing_switch_id}).state;
          then:
            - lambda: |-
                id(aura_mouth_smooth) = 0.0f;
                id(aura_speaking_frame) = 0;
            - if:
                condition:
                  lambda: return id(aura_last_speaking_frame) != 0;
                then:
                  - lambda: id(aura_last_speaking_frame) = 0;
                  - lvgl.image.update:
                      id: aura_main_image
                      src: aura_idle_standby_img


  # ----------------------------------------------------
  # AURA - RETRY DOWNLOAD ASSET
  # ----------------------------------------------------
  - interval: 30s
    then:
      - if:
          condition:
            lambda: |-
              return id(${wifi_component_id}).is_connected() &&
                     !id(aura_assets_ready) &&
                     !id(aura_assets_download_started);
          then:
            - lambda: id(aura_assets_download_started) = true;
            - component.update: aura_idle_standby_img

  - interval: 24h
    then:
      - if:
          condition:
            wifi.connected:
          then:
            - if:
                condition:
                  lambda: return id(${fw_update_check_enabled_id});
                then:
                  - script.execute: ${script_check_firmware_version_id} 

  - interval: 5s
    then:
      - if:
          condition:
            lambda: |-
              return id(${va_modalita_continua_id}) &&
                     id(${voice_assistant_id}).is_running() &&
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_thinking_phase_id} &&
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id} &&
                     id(${voice_assistant_phase_global_id}) != ${voice_assist_error_phase_id} &&
                     id(${va_ultimo_input_ms_id}) > 0 &&
                     (millis() - id(${va_ultimo_input_ms_id}) > 60000UL);
          then:
            - logger.log:
                level: INFO
                format: "==== Modalita continua: stop per inattivita"
            - voice_assistant.stop:

esphome:
  name: ${device_name}
  friendly_name: ${friendly}
  min_version: 2026.6.3
  compile_process_limit: 1
  platformio_options:
    board_build.flash_mode: dio
    board_build.f_flash: 80000000L
    board_build.f_cpu: 240000000L
  project:
    name: Waveshare HackMyHome.DisplayTest
    version: ${fw_version}

  on_boot:
    - priority: 600
      then:
        - lambda: |-
            id(aura_boot_finished) = false;
            id(aura_boot_started_ms) = millis();
            id(aura_ui_ready) = false;
            id(aura_download_step) = 0;
            id(aura_boot_progress_step) = 0;
            id(aura_boot_progress_error) = false;
            id(aura_download_status).clear();

    - priority: 375
      then:
        - sensor.template.publish:
            id: ${next_timer_sensor_id}
            state: -1
        - delay: 10min
        - if:
            condition:
              lambda: return id(${init_in_progress_id});
            then:
              - lambda: id(${init_in_progress_id}) = false;

    - priority: -50
      then:
        # Re-apply restored numeric settings to the live audio components.
        - lambda: |-
            if (!std::isnan(id(${mic_gain_number_id}).state)) {
              id(${mic_gain_saved_id}) = id(${mic_gain_number_id}).state;
              if (!id(${mic_mute_switch_id}).state) {
                id(${audio_adc_id}).set_mic_gain(id(${mic_gain_number_id}).state);
              }
            }
            if (!std::isnan(id(${va_gain_factor_number_id}).state)) {
              id(${va_microphone_id}).set_gain_factor(id(${va_gain_factor_number_id}).state);
            }
            if (!std::isnan(id(${va_noise_suppression_number_id}).state)) {
              id(${voice_assistant_id}).set_noise_suppression_level(id(${va_noise_suppression_number_id}).state);
            }

    - priority: -100
      then:
        - lambda: |-
            id(${alarm_time_text_id}).publish_state(id(${saved_alarm_time_id}));
        - lambda: |-
            auto call = id(${alarm_action_select_id}).make_call();
            call.set_option(id(${saved_alarm_action_id}));
            call.perform();
        - lambda: |-
            setenv("TZ", id(${saved_time_zone_id}).c_str(), 1);
            tzset();

        - delay: 500ms
        - lambda: |-
            id(${display_id}).set_invert_colors(true);
            ESP_LOGI(
              "display_fix",
              "Forzato INVERT_ON dopo il setup mipi_spi"
            );
        - delay: 1500ms
        - light.turn_on:
            id: ${display_backlight_id}
            brightness: !lambda return id(ui_brightness_level);
  area: Casa
esp32:
  board: esp32-s3-devkitc-1
  cpu_frequency: 240MHz
  variant: esp32s3
  flash_size: 16MB
  framework:
    type: esp-idf
    version: recommended
    sdkconfig_options:
      CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC: "y"
      COMPILER_OPTIMIZATION_SIZE: "y"
      CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240: "y"
      CONFIG_ESP32S3_DATA_CACHE_64KB: "y"
      CONFIG_ESP32S3_DATA_CACHE_LINE_64B: "y"
      CONFIG_SPIRAM_FETCH_INSTRUCTIONS: "y"
      CONFIG_SPIRAM_RODATA: "y"
      CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=: "y"
      CONFIG_FREERTOS_HZ=: "1000"
      CONFIG_ESPTOOLPY_FLASHMODE_QIO=: "y"
      CONFIG_ESPTOOLPY_FLASHFREQ_120M=: "y"
      CONFIG_SPIRAM_MODE_OCT=: "y"
      CONFIG_SPIRAM_SPEED_120M=: "y"
      CONFIG_COMPILER_OPTIMIZATION_PERF=: "y"
    advanced:
      enable_idf_experimental_features: true

wifi:
  id: ${wifi_component_id}
  ssid: ${ssid}
  password: ${password}
  reboot_timeout: 10min
  manual_ip:
    static_ip: ${ip}
    gateway:   ${gateway}
    subnet:    ${subnet}
    dns1:      ${dns}
    dns2:      8.8.8.8
  on_connect:
    - lambda: id(${improv_ble_in_progress_id}) = false;
    - lambda: id(aura_boot_progress_error) = false;
    - script.execute: aura_refresh_boot_progress
    - lvgl.label.update:
        id: aura_boot_status
        text: "Wi-Fi connesso"
        text_color: 0x8FD7FF
    - script.execute: aura_try_finish_boot
    - delay: 3s
    - script.execute: ${script_check_firmware_version_id}
    - script.execute:
        id: ${script_play_sound_id}
        priority: true
        sound_file: !lambda return id(${wake_word_triggered_sound_id});
    - delay: 1500ms
    - if:
        condition:
          lambda: return !id(aura_assets_ready) && !id(aura_assets_download_started);
        then:
          - lambda: id(aura_assets_download_started) = true;
          - component.update: aura_idle_standby_img

  on_disconnect:
    - if:
        condition:
          lambda: return !id(aura_boot_finished);
        then:
          - script.execute: aura_refresh_boot_progress

  ap:
    ssid: ${device_name}
    password: ${password}

captive_portal:

http_request:
  verify_ssl: true
  timeout: 10s

logger:
  level: ERROR

api:
  id: ${api_component_id}
  encryption:
    key: ${api_key}

  actions:
    - action: set_led_color
      variables:
        red: float
        green: float
        blue: float
      then:
        - lambda: |-
            id(${led_ring_color_r_id}) = std::min(1.0f, std::max(0.0f, red));
            id(${led_ring_color_g_id}) = std::min(1.0f, std::max(0.0f, green));
            id(${led_ring_color_b_id}) = std::min(1.0f, std::max(0.0f, blue));

    - action: start_va
      then:
        - if:
            condition:
              lambda: return id(${va_modalita_continua_id});
            then:
              - voice_assistant.start_continuous:
              - logger.log:
                  level: INFO
                  format: "==== API: VoiceAssistant in modalita continua"
            else:
              - voice_assistant.start:
              - logger.log:
                  level: INFO
                  format: "==== API: VoiceAssistant in modalita singola"

    - action: stop_va
      then:
        - voice_assistant.stop:
        - logger.log:
            level: INFO
            format: "==== API: VoiceAssistant STOP"


    - action: set_alarm_time
      variables:
        alarm_time_hh_mm: string
      then:
        - logger.log:
            level: INFO
            format: "==== API: SET ALARM"
        - lambda: |-
            if (alarm_time_hh_mm.length() == 5 &&
                isdigit(alarm_time_hh_mm[0]) && isdigit(alarm_time_hh_mm[1]) &&
                isdigit(alarm_time_hh_mm[3]) && isdigit(alarm_time_hh_mm[4])) {
              id(${alarm_time_text_id}).publish_state(alarm_time_hh_mm);
              id(${saved_alarm_time_id}) = alarm_time_hh_mm;
            }

    - action: set_time_zone
      variables:
        posix_time_zone: string
      then:
        - logger.log:
            level: INFO
            format: "==== API: SET TIME ZONE"
        - lambda: |-
            setenv("TZ", posix_time_zone.c_str(), 1);
            tzset();
            id(${saved_time_zone_id}) = posix_time_zone;
            id(${script_publish_current_time_id}).execute();

  on_client_connected:
    - logger.log:
        level: INFO
        format: "==== API: CONNECTED"
    - lambda: id(aura_boot_progress_error) = false;
    - script.execute: aura_refresh_boot_progress
    - script.execute:
        id: ${script_play_sound_id}
        priority: true
        sound_file: !lambda return id(${wake_word_triggered_sound_id});
    - delay: 1500ms
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - script.execute: aura_try_finish_boot
    - delay: 100ms

  on_client_disconnected:
    - logger.log:
        level: INFO
        format: "==== API: DISCONNECTED"
    - script.execute: aura_refresh_boot_progress
    - if:
        condition:
          lambda: return !id(aura_boot_finished);
        then:
          - lvgl.label.update:
              id: aura_boot_status
              text: "In attesa di Home Assistant..."
              text_color: 0x8FD7FF

ota:
  - platform: esphome
    id: ${ota_component_id}
    password: ${ota_key}

external_components:
  - source:
      type: git
      url: https://github.com/sw3Dan/waveshare-s2-audio_esphome_voice
      ref: main
    components: [ es8311 ]
    refresh: 0s

# ======================================================
# I2C e PCA9554
# ======================================================
i2c:
  - id: ${i2c_bus_id}
    sda: ${i2c_sda}
    scl: ${i2c_scl}
    scan: true
    frequency: 100kHz
pca9554:
  - id: ${io_expander_id}
    i2c_id: ${i2c_bus_id}
    address: 0x20

# ======================================================
# BACKLIGHT
# ======================================================
output:
  - platform: ledc
    id: ${display_backlight_output_id}
    pin: ${display_bl_pin}
    frequency: 1000Hz
light:
  - platform: monochromatic
    id: ${display_backlight_id}
    name: "Display Backlight"
    output: ${display_backlight_output_id}
    restore_mode: ALWAYS_OFF
    default_transition_length: 250ms

# ======================================================
# I2S AUDIO - OUT + IN con clock condivisi
# ======================================================
i2s_audio:
  - id: ${i2s_output_id}
    i2s_mclk_pin:
      number: ${i2s_mclk}
      allow_other_uses: true
    i2s_bclk_pin:
      number: ${i2s_bclk}
      allow_other_uses: true
    i2s_lrclk_pin:
      number: ${i2s_lrclk}
      allow_other_uses: true

  - id: ${i2s_input_id}
    i2s_mclk_pin:
      number: ${i2s_mclk}
      allow_other_uses: true
    i2s_bclk_pin:
      number: ${i2s_bclk}
      allow_other_uses: true
    i2s_lrclk_pin:
      number: ${i2s_lrclk}
      allow_other_uses: true

# ======================================================
# AUDIO ADC - ES7210 / MICROFONO
# ======================================================
audio_adc:
  - platform: es7210
    id: ${audio_adc_id}
    i2c_id: ${i2c_bus_id}
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: ${i2s_bps_mic}

# ======================================================
# AUDIO DAC - ES8311
# ======================================================
audio_dac:
  - platform: es8311
    id: ${audio_dac_id}
    i2c_id: ${i2c_bus_id}
    address: 0x18
    bits_per_sample: 16bit
    sample_rate: 48000

# ======================================================
# MICROFONO I2S - ES7210
# ======================================================
microphone:
  - platform: i2s_audio
    id: ${microphone_id}
    i2s_audio_id: ${i2s_input_id}
    i2s_din_pin: ${i2s_din}
    adc_type: external
    pdm: false
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: ${i2s_bps_mic}
    use_apll: ${i2s_use_apll}
    mclk_multiple: ${i2s_mclk_multiple}
    # Il microfono riusa i clock generati dal bus speaker.
    i2s_mode: ${i2s_mode_mic}
    channel: left

# ======================================================
# SPEAKER PIPELINE
# ======================================================
speaker:
  # Uscita fisica verso ES8311
  - platform: i2s_audio
    id: ${hw_speaker_id}
    i2s_audio_id: ${i2s_output_id}
    i2s_dout_pin: ${i2s_dout}
    dac_type: external
    audio_dac: es8311_dac
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: ${i2s_bps_spk}
    channel: mono
    use_apll: ${i2s_use_apll}
    i2s_mode: ${i2s_mode_speaker}
    buffer_duration: 500ms
    timeout: never

  # Mixer: media + annunci sullo stesso speaker fisico
  - platform: mixer
    id: ${audio_mixer_speaker_id}
    output_speaker: ${hw_speaker_id}
    source_speakers:
      - id: ${announcement_mixer_input_id}
        timeout: never
      - id: ${media_mixer_input_id}
        timeout: never

  # Resampler media
  - platform: resampler
    id: ${media_resampler_id}
    output_speaker: ${media_mixer_input_id}
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: 16

  # Resampler annunci / TTS
  - platform: resampler
    id: ${announcement_resampler_id}
    output_speaker: ${announcement_mixer_input_id}
    sample_rate: ${i2s_sample_rate}
    bits_per_sample: 16

# ======================================================
# MEDIA PLAYER
# ======================================================
media_player:
  - platform: speaker
    id: ${media_player_id}
    name: "Media Player"

    media_pipeline:
      speaker: ${media_resampler_id}
      format: FLAC
      sample_rate: 48000
      num_channels: 1

    announcement_pipeline:
      speaker: ${announcement_resampler_id}
      format: FLAC
      sample_rate: 48000
      num_channels: 1

    volume_increment: 0.05
    volume_initial: 0.5
    volume_min: 0.05
    volume_max: 1.0

    buffer_size: 500000
    task_stack_in_psram: true

    on_announcement:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: ANNUNCIO"
      - script.execute: aura_stop_music
      - lambda: |-
          id(${display_awake_until_id}) = millis() + 300000UL;
          // Se parte un annuncio e non è il timer, mostriamo la faccina parlante.
          if (!id(${timer_ringing_switch_id}).state) {
            if (id(${voice_assistant_phase_global_id}) != ${voice_assist_waiting_for_command_phase_id}) {
              id(${voice_assistant_phase_global_id}) = ${voice_assist_replying_phase_id};
            }          
          }          
      - mixer_speaker.apply_ducking:
          id: ${media_mixer_input_id}
          decibel_reduction: 0
          duration: 1s

    on_play:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: PLAY"
      - lambda: |-
          id(${display_awake_until_id}) = millis() + 300000UL;

    on_pause:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: PAUSE"
      - script.execute: aura_stop_music

    on_idle:
      - logger.log:
          level: INFO
          format: "==== MEDIAPLAYER: IDLE"
      - script.execute: aura_stop_music
      - script.execute: ${script_ensure_wake_word_running_id}
      - if:
          condition:
            and:
              - switch.is_off: ${timer_ringing_switch_id}
              - not:
                  voice_assistant.is_running:
              - not:
                  media_player.is_announcing: ${media_player_id}
          then:
            - mixer_speaker.apply_ducking:
                id: ${media_mixer_input_id}
                decibel_reduction: 0
                duration: 1.0s

            - logger.log:
                level: INFO
                format: "==== MEDIAPLAYER: IDLE"
            - lambda: |-
                if (!id(${voice_assistant_id}).is_running() &&
                    !id(${timer_ringing_switch_id}).state) {
                  id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
                }
            - script.execute: aura_stop_speaking

    files:
      - id: ${mute_switch_on_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/mute_switch_on.flac
      - id: ${mute_switch_off_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/mute_switch_off.flac
      - id: ${timer_finished_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/timer_finished.flac
      - id: ${wake_word_triggered_sound_id}
        file: https://github.com/esphome/home-assistant-voice-pe/raw/dev/sounds/wake_word_triggered.flac

# ======================================================
# VOICE ASSISTANT
# ======================================================
voice_assistant:
  id: ${voice_assistant_id}
  microphone:
    id: ${va_microphone_id}
    microphone: ${microphone_id}
    channels: $which_mic
  media_player: ${media_player_id}
  micro_wake_word: ${micro_wake_word_id}
  use_wake_word: false
  noise_suppression_level: 0
  auto_gain: 0 dbfs
  volume_multiplier: 1

  on_client_connected:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: CONNECTED"
    - micro_wake_word.stop:
    - if:
        condition:
          and:
            - lambda: return id(${init_in_progress_id});
            - switch.is_on: ${mic_mute_switch_id}
        then:
          - switch.turn_off: ${mic_mute_switch_id}
    - lambda: id(${init_in_progress_id}) = false;
    - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - delay: 800ms
    - script.execute: ${script_ensure_wake_word_running_id}

  on_client_disconnected:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: DISCONNECTED"
    - voice_assistant.stop:
    - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_not_ready_phase_id};

  on_error:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: ERROR"
    - if:
        condition:
          and:
            - lambda: return !id(${init_in_progress_id});
            - lambda: return code != "duplicate_wake_up_detected";
            - lambda: return code != "stt-no-text-recognized";
        then:
          - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_error_phase_id};

  on_start:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: ON_START"
    - lambda: |-
        id(${va_ultimo_input_ms_id}) = millis();
    - mixer_speaker.apply_ducking:
        id: ${media_mixer_input_id}
        decibel_reduction: 30
        duration: 0.0s

  on_listening:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: LISTENING"
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_waiting_for_command_phase_id};
        id(${va_ultimo_input_ms_id}) = millis();

  on_stt_vad_start:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: VAD_START"
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_listening_for_command_phase_id};
        id(${va_ultimo_input_ms_id}) = millis();

  on_stt_vad_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: VAD_END"
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_thinking_phase_id};
        id(${va_ultimo_input_ms_id}) = millis();

  on_intent_progress:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: INTENT_PROGRESS"
    - if:
        condition:
          lambda: 'return !x.empty();'
        then:
          - script.execute: ${script_activate_stop_word_once_id}

  on_tts_start:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: TTS_START"
    - lambda: |-
        id(${va_ultimo_input_ms_id}) = millis();
    - if:
        condition:
          lambda: 'return id(${voice_assistant_phase_global_id}) != ${voice_assist_replying_phase_id};'
        then:
          - script.execute: ${script_activate_stop_word_once_id}

  on_tts_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: TTS_END"
    - script.execute:
        id: ${script_send_tts_uri_event_id}
        tts_uri: !lambda 'return x;'

  on_stt_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: STT_END"
    - lambda: |-
        id(${va_ultimo_input_ms_id}) = millis();
        id(${local_cmd_code_id}) = 0;
    - script.execute:
        id: ${script_send_stt_text_event_id}
        stt_text: !lambda 'return x;'

    - lambda: |-
        id(${local_cmd_code_id}) = 0;
        std::string t = x;
        std::transform(t.begin(), t.end(), t.begin(),
          [](unsigned char c) { return std::tolower(c); });

        auto has = [&](const char *term) -> bool {
          return t.find(term) != std::string::npos;
        };

        // ===== modalità silenziosa =====
        if (has("$silent_mode") || has("$silent_mode_acc")) {
          id(${local_cmd_code_id}) = 1;
        // ===== volume locale =====
        } else if ((has("$up") || has("$increase")) && has("$volume")) {
          id(${local_cmd_code_id}) = 2;
        } else if ((has("$down") || has("$reduce")) && has("$volume")) {
          id(${local_cmd_code_id}) = 3;

        // ===== antifurto locale =====
        } else if ((has("$enable") || has("$allow") || has("$arm")) &&
                 has("$alarm")) {
          id(${local_cmd_code_id}) = 4;
        } else if ((has("$disable") || has("$deny") || has("$disarm")) &&
                   has("$alarm")) {
          id(${local_cmd_code_id}) = 5;
        }

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 1;'
        then:
          - media_player.stop: ${media_player_id}
    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 2;'
        then:
          - script.execute: ${script_va_local_volume_up_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 3;'
        then:
          - script.execute: ${script_va_local_volume_down_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 4;'
        then:
          - script.execute: ${script_va_local_alarm_on_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) == 5;'
        then:
          - script.execute: ${script_va_local_alarm_off_id}

    - if:
        condition:
          lambda: 'return id(${local_cmd_code_id}) != 0;'
        then:
          - logger.log:
              level: INFO
              format: "==== VOICEASSISTANT: LOCAL INTENT -> stop pipeline"
          - voice_assistant.stop:
          - script.execute: ${script_ensure_wake_word_running_id}
          - lambda: |-
              id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_end:
    - logger.log:
        level: INFO
        format: "==== VOICEASSISTANT: ON_END"
    - wait_until:
        not:
          voice_assistant.is_running:
    - mixer_speaker.apply_ducking:
          id: ${media_mixer_input_id}
          decibel_reduction: 0
          duration: 1.0s
    - if:
        condition:
          lambda: return id(${voice_assistant_phase_global_id}) == ${voice_assist_error_phase_id};
        then:
          - delay: 1s
    - lambda: id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - script.execute: ${script_ensure_wake_word_running_id}

  on_timer_finished:
    - switch.turn_on: ${timer_ringing_switch_id}
    - lambda: |-
        id(${next_timer_sensor_id}).publish_state(-1);
        id(${next_timer_name_sensor_id}).publish_state("-");
        id(${va_timer_total_seconds_id}) = 0;
        id(${va_timer_seconds_left_id})  = 0;
        id(${va_timer_active_display_id}) = false;
    - voice_assistant.stop:
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_timer_started:
    - lambda: |-
        id(${script_check_if_timers_active_id}).execute();
        if (id(${is_timer_active_id})) {
          id(${script_fetch_first_active_timer_id}).execute();
          id(${next_timer_sensor_id}).publish_state(id(${first_active_timer_id}).seconds_left);
          id(${next_timer_name_sensor_id}).publish_state(id(${first_active_timer_id}).name);
          id(${va_timer_total_seconds_id}) = id(${first_active_timer_id}).total_seconds;
          id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
          id(${va_timer_last_tick_ms_id})  = millis();
          id(${va_timer_active_display_id}) = true;
          id(${va_timer_name_display_id}) = id(${first_active_timer_id}).name;
        }
    - voice_assistant.stop: 
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};
    - voice_assistant.stop:
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_timer_cancelled:
    - lambda: |-
        id(${script_check_if_timers_active_id}).execute();
        if (id(${is_timer_active_id})) {
          id(${script_fetch_first_active_timer_id}).execute();
          id(${next_timer_sensor_id}).publish_state(id(${first_active_timer_id}).seconds_left);
          id(${next_timer_name_sensor_id}).publish_state(id(${first_active_timer_id}).name);
          id(${va_timer_total_seconds_id}) = id(${first_active_timer_id}).total_seconds;
          id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
          id(${va_timer_last_tick_ms_id})  = millis();
          id(${va_timer_active_display_id}) = id(${first_active_timer_id}).is_active;
          id(${va_timer_name_display_id}) = id(${first_active_timer_id}).name;
        } else {
          id(${next_timer_sensor_id}).publish_state(-1);
          id(${next_timer_name_sensor_id}).publish_state("-");
          id(${va_timer_total_seconds_id}) = 0;
          id(${va_timer_seconds_left_id})  = 0;
          id(${va_timer_active_display_id}) = false;
          id(${va_timer_name_display_id}) = "";
        }
    - voice_assistant.stop:
    - script.execute: ${script_ensure_wake_word_running_id}
    - lambda: |-
        id(${voice_assistant_phase_global_id}) = ${voice_assist_idle_phase_id};

  on_timer_updated:
    - lambda: |-
        id(${script_check_if_timers_active_id}).execute();
        if (id(${is_timer_active_id})) {
          id(${script_fetch_first_active_timer_id}).execute();
          id(${next_timer_sensor_id}).publish_state(id(${first_active_timer_id}).seconds_left);
          id(${next_timer_name_sensor_id}).publish_state(id(${first_active_timer_id}).name);
          id(${va_timer_total_seconds_id}) = id(${first_active_timer_id}).total_seconds;
          id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
          id(${va_timer_last_tick_ms_id})  = millis();
          id(${va_timer_active_display_id}) = id(${first_active_timer_id}).is_active;
          id(${va_timer_name_display_id}) = id(${first_active_timer_id}).name;
        }

  on_timer_tick:
    - lambda: |-
        id(${script_fetch_first_active_timer_id}).execute();
        int seconds_left = id(${first_active_timer_id}).seconds_left;
        if (seconds_left % 5 == 0) {
          id(${next_timer_sensor_id}).publish_state(seconds_left);
        }
        id(${va_timer_seconds_left_id})  = id(${first_active_timer_id}).seconds_left;
        id(${va_timer_last_tick_ms_id})  = millis();

# ======================================================
# IMICRO WAKE WORD
# ======================================================
micro_wake_word:
  id: ${micro_wake_word_id}
  microphone: ${microphone_id}
  stop_after_detection: false
  models:
    - model: https://github.com/kahrendt/microWakeWord/releases/download/okay_nabu_20241226.3/okay_nabu.json
      id: ${wake_word_okay_nabu_model_id}
    - model: https://raw.githubusercontent.com/formatBCE/Respeaker-Lite-ESPHome-integration/refs/heads/main/microwakeword/models/v2/kenobi.json
      id: ${wake_word_kenobi_model_id}
    - model: ${wake_word_hey_jarvis_model_id}
      id: ${wake_word_hey_jarvis_model_id}
    - model: https://github.com/kahrendt/microWakeWord/releases/download/stop/stop.json
      id: ${wake_word_stop_model_id}
      internal: true

  on_wake_word_detected:
    - logger.log:
        level: INFO
        format: "==== MWW: WORD DETECTED"

    - if:
        condition:
          switch.is_off: ${mic_mute_switch_id}
        then:
          - if:
              condition:
                switch.is_on: ${timer_ringing_switch_id}
              then:
                - switch.turn_off: ${timer_ringing_switch_id}

              else:
                - if:
                    condition:
                      voice_assistant.is_running:
                    then:
                      - voice_assistant.stop:

                    else:
                      - if:
                          condition:
                            media_player.is_announcing: ${media_player_id}
                          then:
                            - media_player.stop:
                                announcement: true

                      - script.execute:
                          id: ${script_start_va_from_wake_word_id}
                          detected_wake_word: !lambda return wake_word;

