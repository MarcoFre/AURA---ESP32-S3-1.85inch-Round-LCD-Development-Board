                    switch.is_on: ${antifurto_switch_id}
                  then:
                    - switch.turn_off: ${antifurto_switch_id}
                  else:
                    - switch.turn_on: ${antifurto_switch_id}
              - lambda: id(control_page_until) = millis() + 15000UL;
              - script.execute: aura_refresh_controls
            widgets:
              - label:
                  id: aura_alarm_label
                  align: CENTER
                  text: "ALLARME OFF"
                  text_font: montserrat_14
                  text_color: 0xFFFFFF

        - button:
            id: aura_back_button
            x: 100
            y: 300
            width: 160
            height: 40
            radius: 20
            bg_color: 0x111827
            border_width: 1
            border_color: 0x475569
            on_click:
              - script.execute: aura_show_main_page
            widgets:
              - label:
                  align: CENTER
                  text: "TORNA AD AURA"
                  text_font: montserrat_14
                  text_color: 0xCBD5E1


# ======================================================
# SENSORI
# ======================================================
select:
  - platform: template
    name: "Display - Emozione"
    id: ${emotion_select_id}
    optimistic: true
    restore_value: true
    options:
      - "Auto"
      - "Felice"
      - "Assonnato"
      - "Triste"
      - "Arrabbiato"
      - "Sorpreso"
    initial_option: "Auto"
    set_action:
      - lambda: |-
          if      (x == "Felice")      id(${display_emotion_mode_id}) = 1;
          else if (x == "Assonnato")   id(${display_emotion_mode_id}) = 2;
          else if (x == "Triste")      id(${display_emotion_mode_id}) = 3;
          else if (x == "Arrabbiato")  id(${display_emotion_mode_id}) = 4;
          else if (x == "Sorpreso")    id(${display_emotion_mode_id}) = 5;
          else                         id(${display_emotion_mode_id}) = 0;
          id(${display_awake_until_id}) = millis() + 300000UL;
      - script.execute: aura_apply_phase

  - platform: template
    name: "WakeWord - Sensibilita"
    optimistic: true
    initial_option: "Medio"
    restore_value: true
    entity_category: config
    options:
      - "Poco sensibile"
      - "Medio"
      - "Molto sensibile"
    on_value:
      lambda: |-
        if (x == "Poco sensibile") {
          id(${wake_word_okay_nabu_model_id}).set_probability_cutoff(217);
        } else if (x == "Medio") {
          id(${wake_word_okay_nabu_model_id}).set_probability_cutoff(176);
        } else if (x == "Molto sensibile") {
          id(${wake_word_okay_nabu_model_id}).set_probability_cutoff(50);
        }

  - platform: logger
    id: ${logger_select_id}
    name: "Livello log"
    disabled_by_default: true

  - platform: template
    optimistic: true
    name: "Sveglia - Azione"
    id: ${alarm_action_select_id}
    icon: mdi:bell-plus
    options:
      - "Riproduci suono"
      - "Invia evento"
      - "Suono ed evento"
    initial_option: "Riproduci suono"
    on_value:
      then:
        - lambda: |-
            id(${saved_alarm_action_id}) = x;

switch:
  - platform: template
    id: ${antifurto_switch_id}
    name: "Modalità antifurto"
    icon: mdi:shield-home
    optimistic: true
    restore_mode: RESTORE_DEFAULT_OFF
    turn_on_action:
      - lambda: |-
          id(${display_awake_until_id}) = millis() + 300000UL;
          id(${display_startled_until_id}) = 0;
    turn_off_action:
      - lambda: |-
          id(${antifurto_alarm_in_corso_id}) = false;

  - platform: template
    id: ${va_continuous_mode_switch_id}
    name: "Assistente - Ascolto continuo"
    icon: mdi:headset
    restore_mode: RESTORE_DEFAULT_ON
    lambda: |-
      return id(${va_modalita_continua_id});
    turn_on_action:
      - lambda: |-
          id(${va_modalita_continua_id}) = true;
      - logger.log:
          level: INFO
          format: "==== Modalita assistente: CONTINUA"
    turn_off_action:
      - lambda: |-
          id(${va_modalita_continua_id}) = false;
      - logger.log:
          level: INFO
          format: "==== Modalita assistente: SINGOLA"
      - if:
          condition:
            voice_assistant.is_running:
          then:
            - voice_assistant.stop:

  - platform: gpio
    id: ${amp_enable_switch_id}
    name: "Amplificatore"
    icon: mdi:speaker
    entity_category: config
    pin:
      number: ${amp_ctrl}
      inverted: false
    restore_mode: RESTORE_DEFAULT_ON

  - platform: template
    id: ${mic_mute_switch_id}
    name: "Microfono disattivato"
    icon: mdi:microphone-off
    optimistic: true
    restore_mode: RESTORE_DEFAULT_OFF
    turn_on_action:
      - voice_assistant.stop:
      - micro_wake_word.stop:
      - lambda: |-
          id(${audio_adc_id}).set_mic_gain(0.0f);
    turn_off_action:
      - lambda: |-
          id(${audio_adc_id}).set_mic_gain(id(${mic_gain_saved_id}));
      - script.execute: ${script_ensure_wake_word_running_id}

  - platform: template
    id: ${mute_sound_switch_id}
    name: "Suono Mute-Unmute"
    icon: "mdi:bullhorn"
    entity_category: config
    optimistic: true
    restore_mode: RESTORE_DEFAULT_ON

  - platform: template
    id: ${wake_sound_switch_id}
    name: "Suono Wake Word"
    icon: "mdi:bullhorn"
    entity_category: config
    optimistic: true
    restore_mode: RESTORE_DEFAULT_ON

  - platform: template
    id: ${timer_ringing_switch_id}
    optimistic: true
    internal: true
    restore_mode: ALWAYS_OFF

    on_turn_off:
      - micro_wake_word.disable_model: ${wake_word_stop_model_id}
      - script.execute: ${script_disable_repeat_id}

      - if:
          condition:
            media_player.is_announcing:
              id: ${media_player_id}
          then:
            - media_player.stop:
                id: ${media_player_id}
                announcement: true

      - mixer_speaker.apply_ducking:
          id: ${media_mixer_input_id}
          decibel_reduction: 0
          duration: 1.0s

    on_turn_on:
      - mixer_speaker.apply_ducking:
          id: ${media_mixer_input_id}
          decibel_reduction: 10
          duration: 0s

      - micro_wake_word.enable_model: ${wake_word_stop_model_id}
      - script.execute: ${script_ring_timer_id}

      - delay: 15min
      - switch.turn_off: ${timer_ringing_switch_id}

  - platform: template
    optimistic: true
    restore_mode: RESTORE_DEFAULT_OFF
    id: ${alarm_on_switch_id}
    icon: mdi:bell-badge
    name: "Sveglia attiva"

  - platform: template
    id: ${fw_update_check_switch_id}
    name: "Controllo nuovo firmware"
    icon: mdi:update
    restore_mode: RESTORE_DEFAULT_ON
    lambda: |-
      return id(${fw_update_check_enabled_id});
    turn_on_action:
      - lambda: |-
          id(${fw_update_check_enabled_id}) = true;
      - script.execute: ${script_check_firmware_version_id}
    turn_off_action:
      - lambda: |-
          id(${fw_update_check_enabled_id}) = false;
          id(${fw_update_available_id}) = false;
          id(${fw_latest_version_id}) = "unknown";

number:
  - platform: template
    id: ${noise_threshold_number_id}
    name: "Soglia Rumore"
    icon: mdi:waveform
    entity_category: config
    optimistic: true
    restore_value: true
    min_value: -75
    max_value: -25
    step: 1
    initial_value: -55
    mode: slider

  - platform: template
    id: ${mic_gain_number_id}
    name: "Mic-Guadagno"
    icon: mdi:microphone
    entity_category: config
    min_value: 0
    max_value: 42
    step: 1
    restore_value: true
    initial_value: 24
    set_action:
      - lambda: |-
          id(${mic_gain_saved_id}) = x;
          if (!id(${mic_mute_switch_id}).state) {
            id(${audio_adc_id}).set_mic_gain(x);
          }
      - logger.log:
          format: "[MIC] Set ES7210 gain to %.0f dB"
          args: ["x"]

  - platform: template
    id: ${va_gain_factor_number_id}
    name: "VA-Guadagno"
    icon: mdi:microphone
    entity_category: config
    min_value: 1
    max_value: 64
    step: 1
    restore_value: true
    initial_value: 32
    set_action:
      - lambda: |-
          id(${va_microphone_id}).set_gain_factor(x);
      - logger.log:
          format: "[MIC] Set gain factor to %.0f"
          args: ["x"]

  - platform: template
    id: ${va_noise_suppression_number_id}
    name: "Sopp. Rumore"
    icon: mdi:waveform
    entity_category: config
    min_value: 0
    max_value: 4
    step: 1
    restore_value: true
    initial_value: 4
    set_action:
      - lambda: |-
          id(${voice_assistant_id}).set_noise_suppression_level(x);
      - logger.log:
          format: "[MIC] Set suppression to %.0f"
          args: ["x"]

sensor:
  - platform: template
    id: ${ambient_noise_sensor_id}
    icon: mdi:microphone
    unit_of_measurement: dB
    accuracy_decimals: 1
    update_interval: 200ms
    internal: true
    lambda: |-
      if (std::isnan(id(${playback_peak_sensor_id}).state)) return NAN;
      return id(${playback_peak_sensor_id}).state;

  - platform: sound_level
    id: ${playback_meter_sensor_id}
    microphone:
      microphone: ${microphone_id}
      channels: [0]
    passive: false
    measurement_duration: 150ms
    rms:
      id: ${playback_rms_sensor_id}
      internal: true
    peak:
      id: ${playback_peak_sensor_id}
      internal: true

  - platform: template
    id: ${next_timer_sensor_id}
    name: "Prossimo timer"
    update_interval: never
    disabled_by_default: true
    device_class: duration
    unit_of_measurement: s
    icon: "mdi:timer"
    accuracy_decimals: 0

text_sensor:
  - platform: template
    id: ${next_timer_name_sensor_id}
    name: "Prossimo timer - Nome"
    icon: "mdi:timer"
    disabled_by_default: true

  - platform: template
    name: "Ora sveglia"
    id: ${alarm_time_text_id}
    icon: mdi:bell-ring

  - platform: template
    name: "Ora dispositivo"
    id: ${current_time_text_id}
    icon: mdi:clock

button:
  - platform: template
    name: "Test antifurto"
    icon: mdi:alarm-light
    on_press:
      - script.execute: ${script_antifurto_trigger_id}

  - platform: factory_reset
    id: ${factory_reset_button_id}
    name: "Ripristino di fabbrica"
    entity_category: diagnostic
    internal: true

  - platform: restart
    id: ${restart_button_id}
    name: "Riavvia"
    entity_category: diagnostic
    disabled_by_default: true
    icon: "mdi:restart"

  - platform: template
    name: "Controlla nuovo firmware"
    icon: mdi:update
    on_press:
      - script.execute: ${script_check_firmware_version_id}

binary_sensor:
  - platform: template
    id: ${noise_detected_binary_sensor_id}
    name: "Rilevamento rumore"
    lambda: |-
      if (std::isnan(id(${playback_peak_sensor_id}).state)) return false;

      // Evita auto-trigger mentre il device sta già suonando/parlando
      if (id(${antifurto_alarm_in_corso_id})) return false;

      const auto s = id(${media_player_id}).state;
      if (s == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_PLAYING ||
          s == media_player::MediaPlayerState::MEDIA_PLAYER_STATE_ANNOUNCING ||
          id(${timer_ringing_switch_id}).state) {
        return false;
      }

      return id(${playback_peak_sensor_id}).state > id(${noise_threshold_number_id}).state;
    filters:
      - delayed_on: 150ms
      - delayed_off: 1200ms
    on_press:
      - lambda: id(aura_last_activity_ms) = millis();
      - script.execute: aura_wake_up
      - if:
          condition:
            switch.is_on: ${antifurto_switch_id}
          then:
            - script.execute: ${script_antifurto_trigger_id}
